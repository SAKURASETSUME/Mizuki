---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

const posts = await getCollection('posts');

const categoryMap = {};
posts.forEach(post => {
  const cats = post.data.categories || [];
  let level = categoryMap;
  cats.forEach((cat, i) => {
    if (!level[cat]) level[cat] = { _items: [], _children: {} };
    if (i === cats.length - 1) level[cat]._items.push(post);
    level = level[cat]._children;
  });
});

function renderCategories(obj, indent = 0) {
  let html = '';
  for (const cat in obj) {
    const data = obj[cat];
    html += `<div style="margin-left:${indent*10}px; font-weight:500; margin-top:4px;">${cat}</div>`;
    if (data._items.length) {
      data._items.forEach(item => {
        html += `<div style="margin-left:${indent*10+15}px; font-size:14px; margin-top:2px;">
          <a href="${item.data.permalink}" style="color:#333; text-decoration:none;">${item.data.title}</a>
        </div>`;
      });
    }
    html += renderCategories(data._children, indent + 1);
  }
  return html;
}
---

<Layout title="归档">
<div style="display:flex; gap:2rem; max-width:1100px; margin:0 auto; padding:2rem 1rem;">
  <div style="width:250px; flex-shrink:0;">
    <div style="background:#fff; border-radius:10px; padding:1rem; box-shadow:0 2px 8px rgba(0,0,0,0.05);">
      <h3 style="margin-top:0;">分类目录</h3>
      <div style="line-height:1.6;">
        {renderCategories(categoryMap)}
      </div>
    </div>
  </div>

  <div style="flex:1;">
    <h1>归档</h1>
    <div style="display:flex; flex-direction:column; gap:0.7rem; margin-top:1rem;">
      {posts.map(post => (
        <div style="background:#fff; padding:0.8rem 1rem; border-radius:8px; box-shadow:0 1px 4px rgba(0,0,0,0.04); display:flex; justify-content:space-between;">
          <a href={post.data.permalink} style="color:#222; text-decoration:none;">{post.data.title}</a>
          <span style="color:#888; font-size:13px;">{new Date(post.data.date).toLocaleDateString()}</span>
        </div>
      ))}
    </div>
  </div>
</div>
</Layout>